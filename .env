# Database (Prisma / SQLite — local demo)
DATABASE_URL=file:/home/z/my-project/db/custom.db

# Supabase (leave as placeholder to run in DEMO mode; fill with real values to enable Supabase mode)
# The isSupabaseConfigured() helper in src/lib/supabase/mode.ts treats the
# `your-project` placeholder as "not configured", so the app falls back to
# the in-memory demo store automatically.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-placeholder
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-placeholder